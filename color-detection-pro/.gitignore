# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/

# Distribution / packaging
build/
dist/
*.egg-info/

# Generated output (keep folders, ignore generated content)
outputs/images/*
!outputs/images/.gitkeep
outputs/videos/*
!outputs/videos/.gitkeep
outputs/detection_statistics.csv
screenshots/*
!screenshots/.gitkeep
logs/*
!logs/.gitkeep

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
